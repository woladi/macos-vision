{
  "name": "macos-vision",
  "version": "1.0.0",
  "description": "Apple Vision OCR & image analysis for Node.js — native, fast, offline, no API keys",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build-native": "node scripts/build-native.js",
    "postinstall": "node scripts/build-native.js",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "ocr",
    "macos",
    "apple-vision",
    "image",
    "text-extraction",
    "vision",
    "native",
    "offline"
  ],
  "author": "Adrian Wolczuk",
  "license": "MIT",
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
