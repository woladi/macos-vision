{
  "name": "macos-vision",
  "version": "0.1.3",
  "description": "Apple Vision OCR & image analysis for Node.js — native, fast, offline, no API keys",
  "author": "Adrian Wolczuk",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "macos-vision": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woladi/macos-vision.git"
  },
  "scripts": {
    "build-native": "node scripts/build-native.js",
    "postinstall": "node scripts/build-native.js",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "prepare": "[ -d .git ] && husky || true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ocr",
    "macos",
    "apple-vision",
    "image",
    "text-extraction",
    "vision",
    "native",
    "offline",
    "face-detection",
    "barcode",
    "qr-code",
    "document-detection",
    "image-classification"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
